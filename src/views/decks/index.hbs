<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Mazos</h1>
      <div class="muted">Selecciona un mazo para ver sus cartas y cargar overrides por CSV.</div>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-info" href="/arcanos/export/v2/arcanos.json">Export V2</a>
      <a class="btn btn-outline-light" href="/tarot/lectura">Ir a Lectura</a>
    </div>
  </div>

  <div class="card p-3">
    {{#if decks.length}}
      <form method="GET" action="/decks" class="row g-3 mb-2">
        <div class="col-md-6">
          <label class="form-label">Mazo</label>
          <select name="deck_id" class="form-select" onchange="this.form.submit()">
            {{#each decks}}
              <option value="{{id}}" {{#if (eq id ../selectedDeckId)}}selected{{/if}}>{{nombre}}</option>
            {{/each}}
          </select>
        </div>
      </form>
    {{else}}
      <div class="alert alert-warning mb-2">No hay mazos configurados.</div>
    {{/if}}

    {{#if importResult}}
      {{#if importResult.error}}
        <div class="alert alert-danger mb-2">{{importResult.error}}</div>
      {{else}}
        <div class="alert alert-success mb-2">
          Importación deck_cards OK · created={{importResult.created}} · updated={{importResult.updated}} · skipped={{importResult.skipped}}
        </div>
      {{/if}}
    {{/if}}

    {{#if decks.length}}
      <form method="POST" action="/decks/deck-cards/import/csv/file" enctype="multipart/form-data" class="row g-3 align-items-end mb-3">
        <input type="hidden" name="deck_id" value="{{selectedDeckId}}" />
        <div class="col-md-8">
          <label class="form-label">Importar cartas del mazo (CSV)</label>
          <input class="form-control" type="file" name="deck_cards_csv_file" accept=".csv,text/csv" required />
          <div class="muted mt-1">Headers sugeridos: card_numero, enabled, imagen_url, imagen_thumb_url (opcional: card_kind).</div>
        </div>
        <div class="col-md-4 d-grid">
          <button class="btn btn-outline-info" type="submit">Subir CSV</button>
        </div>
      </form>
    {{/if}}

    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 92px;">Número</th>
            <th style="width: 88px;">Thumb</th>
            <th>Nombre</th>
            <th style="width: 220px;">Palabras clave</th>
            <th style="width: 120px;" class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {{#unless hasArcanos}}
            <tr>
              <td colspan="5" class="py-4">
                <div class="muted">No hay cartas disponibles para este mazo.</div>
              </td>
            </tr>
          {{/unless}}

          {{#each arcanos}}
            <tr>
              <td><span class="badge badge-mystic text-dark">{{numero}}</span></td>
              <td>
                {{#if imagen_thumb_url_resolved}}
                  <img src="{{imagen_thumb_url_resolved}}" alt="{{nombre}}" class="rounded border border-secondary" style="width:64px;height:64px;object-fit:cover;" loading="lazy" />
                {{else}}
                  {{#if imagen_url_resolved}}
                    <img src="{{imagen_url_resolved}}" alt="{{nombre}}" class="rounded border border-secondary" style="width:64px;height:64px;object-fit:cover;" loading="lazy" />
                  {{else}}
                    <div class="muted">—</div>
                  {{/if}}
                {{/if}}
              </td>
              <td>
                <a class="fw-semibold text-info" href="/arcanos/{{id}}">{{nombre}}</a>
              </td>
              <td class="text-truncate" style="max-width: 220px;">{{palabras_clave}}</td>
              <td class="text-end">
                <a class="btn btn-sm btn-outline-light" href="/arcanos/{{id}}">Ver</a>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</main>

