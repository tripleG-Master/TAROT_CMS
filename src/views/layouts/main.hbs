<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}} · Tarot CMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/darkly/bootstrap.min.css" rel="stylesheet">
    <style>
      :root { --mystic-1:#7c4dff; --mystic-2:#2dd4bf; }
      body {
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
        background: radial-gradient(1200px 500px at 20% -10%, rgba(124,77,255,.25), rgba(0,0,0,0)),
                    radial-gradient(900px 400px at 90% 10%, rgba(45,212,191,.15), rgba(0,0,0,0)),
                    #0b0f14;
      }
      .brand { font-family: Cinzel, serif; letter-spacing: .04em; }
      .card { border: 1px solid rgba(255,255,255,.08); background-color: rgba(13,18,26,.8); }
      .table { --bs-table-bg: rgba(13,18,26,.55); }
      .badge-mystic { background: linear-gradient(90deg, var(--mystic-1), var(--mystic-2)); }
      .btn-mystic { background: linear-gradient(90deg, var(--mystic-1), var(--mystic-2)); border: 0; }
      .btn-mystic:hover { filter: brightness(1.05); }
      a { text-decoration: none; }
      .form-control, .form-select { background-color: rgba(9,12,18,.7); border-color: rgba(255,255,255,.12); }
      .form-control:focus, .form-select:focus { border-color: rgba(124,77,255,.6); box-shadow: 0 0 0 .25rem rgba(124,77,255,.15); }
      .muted { color: rgba(255,255,255,.72); }
    </style>
  </head>
  <body>
    {{> nav}}
    {{{body}}}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
