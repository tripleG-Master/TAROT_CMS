<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">{{heading}}</h1>
      <div class="muted">Completa los campos y guarda cambios.</div>
    </div>
    <a class="btn btn-outline-light" href="/arcanos">Volver</a>
  </div>

  <div class="card p-4">
    <form method="POST" action="{{formAction}}">
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label">Nombre</label>
          <input name="nombre" class="form-control {{#if errors.nombre}}is-invalid{{/if}}" value="{{arcano.nombre}}" placeholder="El Loco, La Emperatriz..." />
          {{#if errors.nombre}}<div class="invalid-feedback">{{errors.nombre}}</div>{{/if}}
        </div>
        <div class="col-md-4">
          <label class="form-label">Número (0-21)</label>
          <input name="numero" inputmode="numeric" class="form-control {{#if errors.numero}}is-invalid{{/if}}" value="{{arcano.numero}}" placeholder="0" />
          {{#if errors.numero}}<div class="invalid-feedback">{{errors.numero}}</div>{{/if}}
        </div>

        <div class="col-12">
          <label class="form-label">Descripción visual</label>
          <textarea name="descripcion_visual" rows="3" class="form-control">{{arcano.descripcion_visual}}</textarea>
        </div>

        <div class="col-md-6">
          <label class="form-label">Significado (Luz)</label>
          <textarea name="significado_luz" rows="5" class="form-control">{{arcano.significado_luz}}</textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Significado (Sombra)</label>
          <textarea name="significado_sombra" rows="5" class="form-control">{{arcano.significado_sombra}}</textarea>
        </div>

        <div class="col-md-8">
          <label class="form-label">Palabras clave (separadas por comas)</label>
          <input name="palabras_clave" class="form-control" value="{{arcano.palabras_clave}}" placeholder="inicio, libertad, intuición" />
        </div>
        <div class="col-md-4">
          <label class="form-label">URL de imagen</label>
          <input name="imagen_url" class="form-control" value="{{arcano.imagen_url}}" placeholder="https://..." />
        </div>

        <div class="col-12">
          <hr class="border-secondary my-2" />
          <div class="fw-semibold">Atributos base</div>
          <div class="muted">Opcional. Pensado para expandir el contenido sin romper V1.</div>
        </div>

        <div class="col-md-6">
          <label class="form-label">Planeta</label>
          <input name="planeta" class="form-control" value="{{arcano.planeta}}" placeholder="Mercurio, Venus..." />
        </div>
        <div class="col-md-6">
          <label class="form-label">Simbología del número</label>
          <input name="numero_simbolismo" class="form-control" value="{{arcano.numero_simbolismo}}" placeholder="La unidad, el punto de origen..." />
        </div>

        <div class="col-12">
          <hr class="border-secondary my-2" />
          <div class="fw-semibold">Simbología técnica</div>
        </div>

        <div class="col-12">
          <label class="form-label">Mesa de elementos</label>
          <textarea name="simbologia_mesa_elementos" rows="2" class="form-control">{{arcano.simbologia_mesa_elementos}}</textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Lemniscata</label>
          <textarea name="simbologia_lemniscata" rows="2" class="form-control">{{arcano.simbologia_lemniscata}}</textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Ropa roja y blanca</label>
          <textarea name="simbologia_ropa" rows="2" class="form-control">{{arcano.simbologia_ropa}}</textarea>
        </div>

        <div class="col-12">
          <hr class="border-secondary my-2" />
          <div class="fw-semibold">Significados por área</div>
        </div>

        <div class="col-md-6">
          <label class="form-label">Amor (Derecho)</label>
          <textarea name="significado_amor_luz" rows="3" class="form-control">{{arcano.significado_amor_luz}}</textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Amor (Invertido)</label>
          <textarea name="significado_amor_sombra" rows="3" class="form-control">{{arcano.significado_amor_sombra}}</textarea>
        </div>

        <div class="col-md-6">
          <label class="form-label">Trabajo (Derecho)</label>
          <textarea name="significado_trabajo_luz" rows="3" class="form-control">{{arcano.significado_trabajo_luz}}</textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Trabajo (Invertido)</label>
          <textarea name="significado_trabajo_sombra" rows="3" class="form-control">{{arcano.significado_trabajo_sombra}}</textarea>
        </div>

        <div class="col-md-6">
          <label class="form-label">Salud (Derecho)</label>
          <textarea name="significado_salud_luz" rows="3" class="form-control">{{arcano.significado_salud_luz}}</textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Salud (Invertido)</label>
          <textarea name="significado_salud_sombra" rows="3" class="form-control">{{arcano.significado_salud_sombra}}</textarea>
        </div>

        <div class="col-12 d-flex align-items-center justify-content-end gap-2 mt-2">
          <a class="btn btn-outline-light" href="{{cancelHref}}">Cancelar</a>
          <button class="btn btn-mystic text-dark fw-semibold" type="submit">Guardar</button>
        </div>
      </div>
    </form>
  </div>
</main>
