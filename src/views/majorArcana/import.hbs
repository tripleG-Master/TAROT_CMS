<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Importar Arcanos</h1>
      <div class="muted">Pega un JSON o CSV/TSV y el CMS hará upsert por número (0–21).</div>
    </div>
    <a class="btn btn-outline-light" href="/arcanos">Volver</a>
  </div>

  {{#if result}}
    <div class="alert alert-success">
      Importación lista: {{result.created}} creados, {{result.updated}} actualizados, {{result.skipped}} omitidos.
    </div>
  {{/if}}

  {{#if error}}
    <div class="alert alert-danger">{{error}}</div>
  {{/if}}

  <div class="card p-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
      <div class="muted">Atajo local</div>
      <form method="POST" action="/arcanos/import/local" class="m-0">
        <button class="btn btn-outline-info" type="submit">Importar data/arcanosMajores.json</button>
      </form>
    </div>
    <hr class="border-secondary my-3" />
    <form method="POST" action="/arcanos/import">
      <label class="form-label">JSON</label>
      <textarea name="json" rows="18" class="form-control" spellcheck="false" placeholder='[{"Número":"0","Nombre":"El Loco",...}]'>{{json}}</textarea>
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-mystic text-dark fw-semibold" type="submit">Importar</button>
      </div>
    </form>

    <hr class="border-secondary my-4" />

    <form method="POST" action="/arcanos/import/csv">
      <label class="form-label">CSV / TSV</label>
      <div class="muted mb-2">Soporta separador por tab (recomendado), coma o punto y coma. La primera fila debe ser el header.</div>
      <textarea name="csv" rows="10" class="form-control" spellcheck="false" placeholder="nombre	numero	palabras_clave	...">{{csv}}</textarea>
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-mystic text-dark fw-semibold" type="submit">Importar CSV</button>
      </div>
    </form>

    <hr class="border-secondary my-4" />

    <form method="POST" action="/arcanos/import/csv/file" enctype="multipart/form-data">
      <label class="form-label">Subir CSV</label>
      <div class="muted mb-2">Selecciona un archivo .csv/.tsv (tab, coma o punto y coma). El header debe coincidir con los campos.</div>
      <input class="form-control" type="file" name="csv_file" accept=".csv,.tsv,text/csv,text/tab-separated-values" required />
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-mystic text-dark fw-semibold" type="submit">Subir e importar</button>
      </div>
    </form>

    <hr class="border-secondary my-4" />

    <div class="fw-semibold mb-2">Conectores</div>
    {{#if connectorsStatus}}
      <div class="alert alert-success">{{connectorsStatus}}</div>
    {{/if}}
    <form method="POST" action="/arcanos/import/connectors">
      <label class="form-label">JSON</label>
      <textarea name="connectorsJson" rows="8" class="form-control" spellcheck="false" placeholder='[{"tipo":"pasado_presente","polaridad":"positivo_negativo","texto":"A pesar de ... {nombre} ..."}]'>{{connectorsJson}}</textarea>
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-outline-info" type="submit">Importar Conectores (JSON)</button>
      </div>
    </form>
    <form method="POST" action="/arcanos/import/connectors/csv" class="mt-3">
      <label class="form-label">CSV / TSV</label>
      <textarea name="connectorsCsv" rows="6" class="form-control" spellcheck="false" placeholder="tipo;polaridad;texto&#10;pasado_presente;positivo_negativo;A pesar de ... {nombre} ...">{{connectorsCsv}}</textarea>
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-outline-info" type="submit">Importar Conectores (CSV)</button>
      </div>
    </form>
    <form method="POST" action="/arcanos/import/connectors/csv/file" enctype="multipart/form-data" class="mt-3">
      <label class="form-label">Subir CSV de Conectores</label>
      <input class="form-control" type="file" name="conn_csv_file" accept=".csv,.tsv,text/csv,text/tab-separated-values" />
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-outline-info" type="submit">Subir e importar</button>
      </div>
    </form>

    <hr class="border-secondary my-4" />

    <div class="fw-semibold mb-2">Mensajes de Arcanos</div>
    {{#if messagesStatus}}
      <div class="alert alert-success">{{messagesStatus}}</div>
    {{/if}}
    <form method="POST" action="/arcanos/import/messages">
      <label class="form-label">JSON</label>
      <textarea name="messagesJson" rows="8" class="form-control" spellcheck="false" placeholder='[{"arcano_id":0,"posicion":"pasado","contexto":"general","perfil_tono":"empático","contenido":"... {nombre} ... preparad{o/a} ..."}]'>{{messagesJson}}</textarea>
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-outline-warning" type="submit">Importar Mensajes (JSON)</button>
      </div>
    </form>
    <form method="POST" action="/arcanos/import/messages/csv" class="mt-3">
      <label class="form-label">CSV / TSV</label>
      <textarea name="messagesCsv" rows="6" class="form-control" spellcheck="false" placeholder="arcano_id;posicion;contexto;perfil_tono;contenido&#10;0;pasado;general;empático;Texto ...">{{messagesCsv}}</textarea>
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-outline-warning" type="submit">Importar Mensajes (CSV)</button>
      </div>
    </form>
    <form method="POST" action="/arcanos/import/messages/csv/file" enctype="multipart/form-data" class="mt-3">
      <label class="form-label">Subir CSV de Mensajes</label>
      <input class="form-control" type="file" name="msg_csv_file" accept=".csv,.tsv,text/csv,text/tab-separated-values" />
      <div class="d-flex align-items-center justify-content-end gap-2 mt-3">
        <button class="btn btn-outline-warning" type="submit">Subir e importar</button>
      </div>
    </form>
  </div>
</main>
