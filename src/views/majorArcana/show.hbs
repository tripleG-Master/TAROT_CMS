<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <div class="d-flex align-items-center gap-2">
        <span class="badge badge-mystic text-dark">{{arcano.numero}}</span>
        <h1 class="h3 brand mb-0">{{arcano.nombre}}</h1>
      </div>
      <div class="muted mt-1">{{arcano.palabras_clave}}</div>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-warning" href="/arcanos/{{arcano.id}}/edit">Editar</a>
      <form method="POST" action="/arcanos/{{arcano.id}}?_method=DELETE" class="d-inline">
        <button class="btn btn-outline-danger" type="submit" onclick="return confirm('¿Eliminar este arcano?');">Eliminar</button>
      </form>
      <a class="btn btn-outline-light" href="/arcanos">Volver</a>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-4">
      <div class="card p-3">
        <div class="fw-semibold mb-2">Imagen</div>
        {{#if arcano.imagen_thumb_url_resolved}}
          <img src="{{arcano.imagen_thumb_url_resolved}}" alt="{{arcano.nombre}}" class="img-fluid rounded border border-secondary" />
          {{#if arcano.imagen_url_resolved}}
            <div class="mt-2 text-truncate"><a href="{{arcano.imagen_url_resolved}}" target="_blank" rel="noreferrer" class="text-info">Abrir imagen full</a></div>
          {{/if}}
        {{else}}
          {{#if arcano.imagen_url_resolved}}
            <img src="{{arcano.imagen_url_resolved}}" alt="{{arcano.nombre}}" class="img-fluid rounded border border-secondary" />
            <div class="mt-2 text-truncate"><a href="{{arcano.imagen_url_resolved}}" target="_blank" rel="noreferrer" class="text-info">{{arcano.imagen_url_resolved}}</a></div>
          {{else}}
            <div class="muted">Sin URL de imagen.</div>
          {{/if}}
        {{/if}}

        {{#if arcano.image_gallery_resolved.length}}
          <hr class="border-secondary my-3" />
          <div class="fw-semibold mb-2">Galería ({{arcano.image_gallery_resolved.length}})</div>
          <div class="row g-2">
            {{#each arcano.image_gallery_resolved}}
              <div class="col-6">
                <a href="{{imagen_url}}" target="_blank" rel="noreferrer">
                  <img src="{{#if imagen_thumb_url}}{{imagen_thumb_url}}{{else}}{{imagen_url}}{{/if}}" alt="galeria" class="img-fluid rounded border border-secondary" />
                </a>
              </div>
            {{/each}}
          </div>
        {{/if}}
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card p-4">
        <div class="row g-4">
          <div class="col-12">
            <div class="fw-semibold mb-1">Descripción visual</div>
            <div class="muted" style="white-space: pre-wrap;">{{arcano.descripcion_visual}}</div>
          </div>
          <div class="col-md-6">
            <div class="fw-semibold mb-1">Significado (Luz)</div>
            <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_luz}}</div>
          </div>
          <div class="col-md-6">
            <div class="fw-semibold mb-1">Significado (Sombra)</div>
            <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_sombra}}</div>
          </div>

          {{#if arcano.planeta}}
            <div class="col-12">
              <hr class="border-secondary my-2" />
              <div class="fw-semibold mb-1">Atributos base</div>
              <div class="muted" style="white-space: pre-wrap;">Planeta: {{arcano.planeta}}</div>
              {{#if arcano.numero_simbolismo}}
                <div class="muted" style="white-space: pre-wrap;">Número (simbología): {{arcano.numero_simbolismo}}</div>
              {{/if}}
            </div>
          {{/if}}

          {{#if arcano.simbologia_mesa_elementos}}
            <div class="col-12">
              <hr class="border-secondary my-2" />
              <div class="fw-semibold mb-1">Simbología técnica</div>
              <div class="muted" style="white-space: pre-wrap;">Mesa de elementos: {{arcano.simbologia_mesa_elementos}}</div>
              {{#if arcano.simbologia_lemniscata}}
                <div class="muted mt-2" style="white-space: pre-wrap;">Lemniscata: {{arcano.simbologia_lemniscata}}</div>
              {{/if}}
              {{#if arcano.simbologia_ropa}}
                <div class="muted mt-2" style="white-space: pre-wrap;">Ropa roja y blanca: {{arcano.simbologia_ropa}}</div>
              {{/if}}
            </div>
          {{/if}}

          {{#if arcano.significado_amor_luz}}
            <div class="col-12">
              <hr class="border-secondary my-2" />
              <div class="fw-semibold mb-1">Significados por área</div>
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="fw-semibold mb-1">Amor (Derecho)</div>
                  <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_amor_luz}}</div>
                </div>
                <div class="col-md-6">
                  <div class="fw-semibold mb-1">Amor (Invertido)</div>
                  <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_amor_sombra}}</div>
                </div>
                <div class="col-md-6">
                  <div class="fw-semibold mb-1">Trabajo (Derecho)</div>
                  <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_trabajo_luz}}</div>
                </div>
                <div class="col-md-6">
                  <div class="fw-semibold mb-1">Trabajo (Invertido)</div>
                  <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_trabajo_sombra}}</div>
                </div>
                <div class="col-md-6">
                  <div class="fw-semibold mb-1">Salud (Derecho)</div>
                  <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_salud_luz}}</div>
                </div>
                <div class="col-md-6">
                  <div class="fw-semibold mb-1">Salud (Invertido)</div>
                  <div class="muted" style="white-space: pre-wrap;">{{arcano.significado_salud_sombra}}</div>
                </div>
              </div>
            </div>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</main>
