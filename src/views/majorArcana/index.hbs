<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Arcanos Mayores</h1>
      <div class="muted">Gestiona los 22 (0–21) y exporta a JSON para Android.</div>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-info" href="/arcanos/export/arcanos.json">Descargar arcanos.json</a>
      <a class="btn btn-mystic text-dark fw-semibold" href="/arcanos/new">Crear Arcano</a>
    </div>
  </div>

  <div class="card p-3">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 92px;">Número</th>
            <th>Nombre</th>
            <th style="width: 220px;">Palabras clave</th>
            <th style="width: 220px;" class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {{#unless hasArcanos}}
            <tr>
              <td colspan="4" class="py-4">
                <div class="muted">Aún no hay arcanos. Crea el primero.</div>
              </td>
            </tr>
          {{/unless}}

          {{#each arcanos}}
            <tr>
              <td><span class="badge badge-mystic text-dark">{{numero}}</span></td>
              <td>
                <a class="fw-semibold text-info" href="/arcanos/{{id}}">{{nombre}}</a>
              </td>
              <td class="text-truncate" style="max-width: 220px;">{{palabras_clave}}</td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <a class="btn btn-sm btn-outline-light" href="/arcanos/{{id}}">Ver</a>
                  <a class="btn btn-sm btn-outline-warning" href="/arcanos/{{id}}/edit">Editar</a>
                  <form method="POST" action="/arcanos/{{id}}?_method=DELETE" class="d-inline">
                    <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('¿Eliminar este arcano?');">Eliminar</button>
                  </form>
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</main>
