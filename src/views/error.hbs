<main class="container py-4">
  <div class="card p-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <h1 class="h4 mb-0">Error <span class="badge badge-mystic text-dark ms-2">{{status}}</span></h1>
      <a class="btn btn-outline-light" href="/arcanos">Volver</a>
    </div>
    <hr class="border-secondary my-3" />
    <div class="muted">{{message}}</div>
  </div>
</main>
