<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <div class="d-flex align-items-center gap-2">
        <span class="badge badge-mystic text-dark">{{item.numero}}</span>
        <h1 class="h3 brand mb-0">{{item.nombre}}</h1>
      </div>
      <div class="muted mt-1">{{item.palo}} {{#if item.valor}}· {{item.valor}}{{/if}}</div>
      {{#if item.palabras_clave}}
        <div class="muted mt-1">{{item.palabras_clave}}</div>
      {{/if}}
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-warning" href="/menores/{{item.id}}/edit">Editar</a>
      <form method="POST" action="/menores/{{item.id}}?_method=DELETE" class="d-inline">
        <button class="btn btn-outline-danger" type="submit" onclick="return confirm('¿Eliminar este arcano menor?');">Eliminar</button>
      </form>
      <a class="btn btn-outline-light" href="/menores">Volver</a>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-4">
      <div class="card p-3">
        <div class="fw-semibold mb-2">Imagen</div>
        {{#if item.imagen_thumb_url_resolved}}
          <img src="{{item.imagen_thumb_url_resolved}}" alt="{{item.nombre}}" class="img-fluid rounded border border-secondary" />
          {{#if item.imagen_url_resolved}}
            <div class="mt-2 text-truncate"><a href="{{item.imagen_url_resolved}}" target="_blank" rel="noreferrer" class="text-info">Abrir imagen full</a></div>
          {{/if}}
        {{else}}
          {{#if item.imagen_url_resolved}}
            <img src="{{item.imagen_url_resolved}}" alt="{{item.nombre}}" class="img-fluid rounded border border-secondary" />
            <div class="mt-2 text-truncate"><a href="{{item.imagen_url_resolved}}" target="_blank" rel="noreferrer" class="text-info">{{item.imagen_url_resolved}}</a></div>
          {{else}}
            <div class="muted">Sin URL de imagen.</div>
          {{/if}}
        {{/if}}
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card p-4">
        <div class="row g-4">
          <div class="col-12">
            <div class="fw-semibold mb-1">Descripción visual</div>
            <div class="muted" style="white-space: pre-wrap;">{{item.descripcion_visual}}</div>
          </div>
          <div class="col-md-6">
            <div class="fw-semibold mb-1">Significado (Luz)</div>
            <div class="muted" style="white-space: pre-wrap;">{{item.significado_luz}}</div>
          </div>
          <div class="col-md-6">
            <div class="fw-semibold mb-1">Significado (Sombra)</div>
            <div class="muted" style="white-space: pre-wrap;">{{item.significado_sombra}}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
