<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Arcanos Menores</h1>
      <div class="muted">CRUD e import/export para Arcanos Menores.</div>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-light" href="/menores/import">Importar</a>
      <a class="btn btn-outline-info" href="/menores/export/v2/arcanos-menores.json">Exportar V2</a>
      <a class="btn btn-mystic text-dark fw-semibold" href="/menores/new">Nuevo</a>
    </div>
  </div>

  <div class="card p-0 overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 92px;">Número</th>
            <th style="width: 88px;">Thumb</th>
            <th>Nombre</th>
            <th style="width: 180px;">Palo</th>
            <th style="width: 180px;">Valor</th>
            <th style="width: 220px;" class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {{#unless hasItems}}
            <tr>
              <td colspan="6" class="py-4">
                <div class="muted">Aún no hay arcanos menores. Crea el primero.</div>
              </td>
            </tr>
          {{/unless}}

          {{#each items}}
            <tr>
              <td><span class="badge badge-mystic text-dark">{{numero}}</span></td>
              <td>
                {{#if imagen_thumb_url_resolved}}
                  <img src="{{imagen_thumb_url_resolved}}" alt="{{nombre}}" class="rounded border border-secondary" style="width:64px;height:64px;object-fit:cover;" loading="lazy" />
                {{else}}
                  {{#if imagen_url_resolved}}
                    <img src="{{imagen_url_resolved}}" alt="{{nombre}}" class="rounded border border-secondary" style="width:64px;height:64px;object-fit:cover;" loading="lazy" />
                  {{else}}
                    <div class="muted">—</div>
                  {{/if}}
                {{/if}}
              </td>
              <td>
                <a class="fw-semibold text-info" href="/menores/{{id}}">{{nombre}}</a>
              </td>
              <td class="text-truncate" style="max-width: 180px;">{{palo}}</td>
              <td class="text-truncate" style="max-width: 180px;">{{valor}}</td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <a class="btn btn-sm btn-outline-light" href="/menores/{{id}}">Ver</a>
                  <a class="btn btn-sm btn-outline-warning" href="/menores/{{id}}/edit">Editar</a>
                  <form method="POST" action="/menores/{{id}}?_method=DELETE" class="d-inline">
                    <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('¿Eliminar este arcano menor?');">Eliminar</button>
                  </form>
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</main>
