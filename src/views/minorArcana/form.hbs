<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">{{heading}}</h1>
      <div class="muted">Completa los campos y guarda cambios.</div>
    </div>
    <a class="btn btn-outline-light" href="{{cancelHref}}">Volver</a>
  </div>

  <form method="POST" action="{{formAction}}" enctype="multipart/form-data">
    <div class="card p-4">
      <div class="row g-3">
        <div class="col-md-2">
          <label class="form-label">Número</label>
          <input class="form-control" name="numero" value="{{item.numero}}" />
          {{#if errors.numero}}<div class="text-danger mt-1">{{errors.numero}}</div>{{/if}}
        </div>
        <div class="col-md-5">
          <label class="form-label">Palo</label>
          <input class="form-control" name="palo" value="{{item.palo}}" placeholder="bastos/copas/espadas/oros" />
        </div>
        <div class="col-md-5">
          <label class="form-label">Valor</label>
          <input class="form-control" name="valor" value="{{item.valor}}" placeholder="as/2...10/sota/caballo/reina/rey" />
        </div>

        <div class="col-12">
          <label class="form-label">Nombre</label>
          <input class="form-control" name="nombre" value="{{item.nombre}}" />
          {{#if errors.nombre}}<div class="text-danger mt-1">{{errors.nombre}}</div>{{/if}}
        </div>

        <div class="col-12">
          <label class="form-label">Palabras clave (separadas por coma)</label>
          <input class="form-control" name="palabras_clave" value="{{item.palabras_clave}}" />
        </div>

        <div class="col-md-6">
          <label class="form-label">Significado (luz)</label>
          <textarea class="form-control" name="significado_luz" rows="6">{{item.significado_luz}}</textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Significado (sombra)</label>
          <textarea class="form-control" name="significado_sombra" rows="6">{{item.significado_sombra}}</textarea>
        </div>

        <div class="col-12">
          <label class="form-label">Descripción visual</label>
          <textarea class="form-control" name="descripcion_visual" rows="4">{{item.descripcion_visual}}</textarea>
        </div>

        <div class="col-md-6">
          <label class="form-label">Imagen URL</label>
          <input class="form-control" name="imagen_url" value="{{item.imagen_url}}" placeholder="/public/img/minor/.." />
        </div>
        <div class="col-md-6">
          <label class="form-label">Thumbnail URL</label>
          <input class="form-control" name="imagen_thumb_url" value="{{item.imagen_thumb_url}}" placeholder="/public/img/minor/thumbs/.." />
        </div>

        <div class="col-12">
          <label class="form-label">Subir imagen (genera thumbnail)</label>
          <input class="form-control" type="file" name="imagen_file" accept="image/*" />
          <div class="muted mt-1">Guarda en /public/img/minor y /public/img/minor/thumbs usando el número.</div>
        </div>
      </div>

      <div class="d-flex align-items-center justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-light" href="{{cancelHref}}">Cancelar</a>
        <button class="btn btn-mystic text-dark fw-semibold" type="submit">{{#if isEdit}}Guardar cambios{{else}}Crear{{/if}}</button>
      </div>
    </div>
  </form>
</main>
