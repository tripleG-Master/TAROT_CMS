<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Mensajes de Arcanos</h1>
      <div class="muted">Filtra por arcano/posición/contexto/tono y revisa el contenido.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <form method="POST" action="/tarot/mensajes/delete-all" onsubmit="return confirm('Esto borrará TODOS los mensajes de arcanos. ¿Continuar?');">
        <button class="btn btn-outline-danger" type="submit">Borrar mensajes</button>
      </form>
      <a class="btn btn-outline-light" href="/tarot/lectura">Volver a Lectura</a>
    </div>
  </div>

  <div class="card p-4">
    {{#if deleted}}
      <div class="alert alert-success">Mensajes borrados: {{deleted}}</div>
    {{/if}}

    <form method="GET" action="/tarot/mensajes" class="row g-3">
      <div class="col-md-2">
        <label class="form-label">Arcano ID</label>
        <input class="form-control" name="arcano_id" value="{{filters.arcano_id}}" placeholder="0–21" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Posición</label>
        <select name="posicion" class="form-select">
          <option value="" {{#unless filters.posicion}}selected{{/unless}}>Todas</option>
          <option value="pasado" {{#if (eq filters.posicion "pasado")}}selected{{/if}}>pasado</option>
          <option value="presente" {{#if (eq filters.posicion "presente")}}selected{{/if}}>presente</option>
          <option value="futuro" {{#if (eq filters.posicion "futuro")}}selected{{/if}}>futuro</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Contexto</label>
        <select name="contexto" class="form-select">
          <option value="" {{#unless filters.contexto}}selected{{/unless}}>Todos</option>
          <option value="general" {{#if (eq filters.contexto "general")}}selected{{/if}}>general</option>
          <option value="amor" {{#if (eq filters.contexto "amor")}}selected{{/if}}>amor</option>
          <option value="salud" {{#if (eq filters.contexto "salud")}}selected{{/if}}>salud</option>
          <option value="dinero" {{#if (eq filters.contexto "dinero")}}selected{{/if}}>dinero</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Tono</label>
        <select name="perfil_tono" class="form-select">
          <option value="" {{#unless filters.perfil_tono}}selected{{/unless}}>Todos</option>
          <option value="general" {{#if (eq filters.perfil_tono "general")}}selected{{/if}}>general</option>
          <option value="empatico" {{#if (eq filters.perfil_tono "empatico")}}selected{{/if}}>empatico</option>
          <option value="directo" {{#if (eq filters.perfil_tono "directo")}}selected{{/if}}>directo</option>
          <option value="mistico" {{#if (eq filters.perfil_tono "mistico")}}selected{{/if}}>mistico</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Polaridad</label>
        <select name="polaridad" class="form-select">
          <option value="" {{#unless filters.polaridad}}selected{{/unless}}>Todas</option>
          <option value="favorable" {{#if (eq filters.polaridad "favorable")}}selected{{/if}}>favorable</option>
          <option value="desafiante" {{#if (eq filters.polaridad "desafiante")}}selected{{/if}}>desafiante</option>
          <option value="neutra" {{#if (eq filters.polaridad "neutra")}}selected{{/if}}>neutra</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Sentido</label>
        <select name="sentido" class="form-select">
          <option value="" {{#unless filters.sentido}}selected{{/unless}}>Todos</option>
          <option value="derecho" {{#if (eq filters.sentido "derecho")}}selected{{/if}}>derecho</option>
          <option value="invertido" {{#if (eq filters.sentido "invertido")}}selected{{/if}}>invertido</option>
          <option value="neutro" {{#if (eq filters.sentido "neutro")}}selected{{/if}}>neutro</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Luz/Sombra</label>
        <select name="luz_sombra" class="form-select">
          <option value="" {{#unless filters.luz_sombra}}selected{{/unless}}>Todos</option>
          <option value="luz" {{#if (eq filters.luz_sombra "luz")}}selected{{/if}}>luz</option>
          <option value="sombra" {{#if (eq filters.luz_sombra "sombra")}}selected{{/if}}>sombra</option>
          <option value="neutra" {{#if (eq filters.luz_sombra "neutra")}}selected{{/if}}>neutra</option>
        </select>
      </div>
      <div class="col-md-12 d-flex align-items-end">
        <button class="btn btn-mystic text-dark fw-semibold w-100" type="submit">Filtrar</button>
      </div>
    </form>

    <hr class="border-secondary my-3" />

    <div class="table-responsive">
      <table class="table table-striped align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 90px;">Arcano</th>
            <th style="width: 110px;">Posición</th>
            <th style="width: 110px;">Contexto</th>
            <th style="width: 110px;">Tono</th>
            <th style="width: 110px;">Polaridad</th>
            <th style="width: 110px;">Sentido</th>
            <th style="width: 110px;">Luz/Sombra</th>
            <th>Contenido</th>
          </tr>
        </thead>
        <tbody>
          {{#each rows}}
            <tr>
              <td><span class="badge bg-secondary">{{arcano_id}}</span></td>
              <td><span class="badge bg-dark">{{posicion}}</span></td>
              <td><span class="badge bg-info text-dark">{{contexto}}</span></td>
              <td><span class="badge bg-warning text-dark">{{perfil_tono}}</span></td>
              <td><span class="badge bg-secondary">{{polaridad}}</span></td>
              <td><span class="badge bg-dark">{{sentido}}</span></td>
              <td><span class="badge bg-dark">{{luz_sombra}}</span></td>
              <td style="white-space: pre-wrap;">{{contenido}}</td>
            </tr>
          {{/each}}
          {{#unless rows}}
            <tr>
              <td colspan="8" class="py-4"><div class="muted">No hay mensajes con estos filtros.</div></td>
            </tr>
          {{/unless}}
        </tbody>
      </table>
    </div>
  </div>
</main>
