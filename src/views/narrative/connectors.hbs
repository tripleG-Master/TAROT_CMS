<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Conectores</h1>
      <div class="muted">Filtra por tipo/polaridad y revisa el texto con placeholders.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <form method="POST" action="/tarot/conectores/delete-all" onsubmit="return confirm('Esto borrará TODOS los conectores. ¿Continuar?');">
        <button class="btn btn-outline-danger" type="submit">Borrar conectores</button>
      </form>
      <a class="btn btn-outline-light" href="/tarot/lectura">Volver a Lectura</a>
    </div>
  </div>

  <div class="card p-4">
    {{#if deleted}}
      <div class="alert alert-success">Conectores borrados: {{deleted}}</div>
    {{/if}}

    <form method="GET" action="/tarot/conectores" class="row g-3">
      <div class="col-md-4">
        <label class="form-label">Tipo</label>
        <select name="tipo" class="form-select">
          <option value="" {{#unless filters.tipo}}selected{{/unless}}>Todos</option>
          <option value="pasado_presente" {{#if (eq filters.tipo "pasado_presente")}}selected{{/if}}>pasado_presente</option>
          <option value="presente_futuro" {{#if (eq filters.tipo "presente_futuro")}}selected{{/if}}>presente_futuro</option>
          <option value="intro" {{#if (eq filters.tipo "intro")}}selected{{/if}}>intro</option>
          <option value="cierre" {{#if (eq filters.tipo "cierre")}}selected{{/if}}>cierre</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Polaridad</label>
        <select name="polaridad" class="form-select">
          <option value="" {{#unless filters.polaridad}}selected{{/unless}}>Todos</option>
          <option value="pos_pos" {{#if (eq filters.polaridad "pos_pos")}}selected{{/if}}>pos_pos</option>
          <option value="pos_neg" {{#if (eq filters.polaridad "pos_neg")}}selected{{/if}}>pos_neg</option>
          <option value="neg_pos" {{#if (eq filters.polaridad "neg_pos")}}selected{{/if}}>neg_pos</option>
          <option value="neg_neg" {{#if (eq filters.polaridad "neg_neg")}}selected{{/if}}>neg_neg</option>
          <option value="neutro" {{#if (eq filters.polaridad "neutro")}}selected{{/if}}>neutro</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Tono</label>
        <select name="perfil" class="form-select">
          <option value="" {{#unless filters.perfil}}selected{{/unless}}>Todos</option>
          <option value="general" {{#if (eq filters.perfil "general")}}selected{{/if}}>general</option>
          <option value="empatico" {{#if (eq filters.perfil "empatico")}}selected{{/if}}>empatico</option>
          <option value="directo" {{#if (eq filters.perfil "directo")}}selected{{/if}}>directo</option>
          <option value="mistico" {{#if (eq filters.perfil "mistico")}}selected{{/if}}>mistico</option>
        </select>
      </div>
      <div class="col-md-12 d-flex align-items-end">
        <button class="btn btn-mystic text-dark fw-semibold w-100" type="submit">Filtrar</button>
      </div>
    </form>

    <hr class="border-secondary my-3" />

    <div class="table-responsive">
      <table class="table table-striped align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 160px;">Tipo</th>
            <th style="width: 180px;">Polaridad</th>
            <th style="width: 120px;">Tono</th>
            <th style="width: 90px;" class="text-end">Peso</th>
            <th>Texto</th>
          </tr>
        </thead>
        <tbody>
          {{#each rows}}
            <tr>
              <td><span class="badge bg-secondary">{{tipo}}</span></td>
              <td><span class="badge bg-dark">{{polaridad}}</span></td>
              <td><span class="badge bg-warning text-dark">{{perfil}}</span></td>
              <td class="text-end"><span class="badge bg-secondary">{{peso}}</span></td>
              <td style="white-space: pre-wrap;">{{texto}}</td>
            </tr>
          {{/each}}
          {{#unless rows}}
            <tr>
              <td colspan="5" class="py-4"><div class="muted">No hay conectores con estos filtros.</div></td>
            </tr>
          {{/unless}}
        </tbody>
      </table>
    </div>
  </div>
</main>
