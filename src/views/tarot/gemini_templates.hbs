<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Gemini · Plantillas</h1>
      <div class="muted">Texto curado listo para reutilizar en futuras lecturas.</div>
    </div>
    <a class="btn btn-outline-light" href="/tarot/gemini">Volver a prueba</a>
  </div>

  <div class="card p-3 mb-3">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">API Token</label>
        <input id="apiToken" class="form-control" type="password" placeholder="Bearer..." />
        <div class="muted mt-1">Token del CMS para poder llamar endpoints /api.</div>
      </div>
    </div>
  </div>

  <div class="card p-3">
    <div class="table-responsive">
      <table class="table table-sm align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>Fecha</th>
            <th>Tema</th>
            <th>Estado</th>
            <th>Contenido</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#if templates.length}}
            {{#each templates}}
              <tr data-id="{{id}}">
                <td class="text-nowrap">{{id}}</td>
                <td class="text-nowrap">{{createdAt}}</td>
                <td class="text-nowrap">{{#if tema}}{{tema}}{{else}}general{{/if}}</td>
                <td class="text-nowrap">
                  {{#if approved}}
                    <span class="badge bg-success">Aprobada</span>
                  {{else}}
                    <span class="badge bg-secondary">Pendiente</span>
                  {{/if}}
                </td>
                <td style="max-width: 420px;">
                  {{#if contenido}}
                    {{contenido}}
                  {{else}}—{{/if}}
                </td>
                <td class="text-end">
                  {{#if approved}}
                    <button class="btn btn-sm btn-outline-warning js-approve">Desaprobar</button>
                  {{else}}
                    <button class="btn btn-sm btn-outline-success js-approve">Aprobar</button>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          {{else}}
            <tr><td colspan="6" class="text-center py-4">Sin plantillas aún.</td></tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </div>
</main>

<script>
  (function () {
    const apiToken = document.getElementById("apiToken");
    apiToken.value = localStorage.getItem("tarotCmsApiToken") || "";
    apiToken.addEventListener("change", () => localStorage.setItem("tarotCmsApiToken", apiToken.value || ""));

    function headers() {
      const h = { "Accept": "application/json", "Content-Type": "application/json" };
      const t = apiToken.value || "";
      if (t) h["Authorization"] = "Bearer " + t;
      return h;
    }

    document.querySelectorAll(".js-approve").forEach((btn) => {
      btn.addEventListener("click", async function () {
        const tr = this.closest("tr");
        const id = tr && tr.getAttribute("data-id");
        if (!id) return;
        const approve = this.textContent.toLowerCase().includes("aprobar");
        try {
          const res = await fetch("/api/gemini/templates/" + id + "/approve", {
            method: "POST",
            headers: headers(),
            body: JSON.stringify({ approved: approve })
          });
          const data = await res.json().catch(() => null);
          if (res.status === 401) return alert("Unauthorized. Pega el API token para usar /api.");
          if (!res.ok || !data || data.ok !== true) return alert((data && data.error) || ("HTTP " + res.status));
          location.reload();
        } catch (err) {
          alert(err && err.message ? err.message : "Error de red");
        }
      });
    });
  })();
</script>
