<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Contenido App</h1>
      <div class="muted">Control centralizado del contenido que consume Android (config + manifest).</div>
    </div>
    <a class="btn btn-outline-light" href="/tarot/calculo">Volver</a>
  </div>

  {{#if saved}}
    <div class="alert alert-success">Guardado.</div>
  {{/if}}
  {{#if error}}
    <div class="alert alert-danger">{{error}}</div>
  {{/if}}

  <div class="row g-3">
    <div class="col-lg-6">
      <div class="card p-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <div class="fw-semibold">App Config</div>
            <div class="muted">id={{app_config.id}} · schema_version={{app_config.schema_version}} · etag={{app_config.etag}}</div>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-info btn-sm" href="/api/app-config" target="_blank" rel="noreferrer">Abrir /api/app-config</a>
            <a class="btn btn-outline-info btn-sm" href="/api/content/manifest" target="_blank" rel="noreferrer">Abrir /api/content/manifest</a>
          </div>
        </div>

        <form method="POST" action="/tarot/content/app-config" class="mt-3">
          <label class="form-label">payload (JSON)</label>
          <textarea class="form-control" name="payload" rows="18" spellcheck="false">{{payloadText}}</textarea>
          <div class="d-flex gap-2 flex-wrap mt-3">
            <button class="btn btn-mystic text-dark fw-semibold" type="submit">Guardar</button>
            <button class="btn btn-outline-secondary" type="button" id="btnLoadFromApi">Cargar desde /api/app-config</button>
          </div>
        </form>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card p-3">
        <div class="fw-semibold">Manifest (preview)</div>
        <div class="muted">Útil para validar ETag/304 y ver recursos que la app debería descargar.</div>
        <div class="d-flex gap-2 flex-wrap mt-2">
          <button class="btn btn-outline-info btn-sm" type="button" id="btnFetchManifest">Fetch manifest</button>
          <button class="btn btn-outline-secondary btn-sm" type="button" id="btnFetchConfig">Fetch app-config</button>
          <button class="btn btn-outline-secondary btn-sm" type="button" id="btnFetchArcV2">Fetch arcanos v2</button>
        </div>

        <div class="mt-3">
          <div class="muted mb-1">HTTP</div>
          <input id="httpStatus" class="form-control" readonly />
        </div>
        <div class="mt-3">
          <div class="muted mb-1">ETag</div>
          <input id="httpEtag" class="form-control" readonly />
        </div>
        <div class="mt-3">
          <div class="muted mb-1">Body</div>
          <textarea id="httpBody" class="form-control" rows="14" spellcheck="false" readonly></textarea>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  (function () {
    const bodyArea = document.getElementById("httpBody");
    const statusInput = document.getElementById("httpStatus");
    const etagInput = document.getElementById("httpEtag");
    const btnFetchManifest = document.getElementById("btnFetchManifest");
    const btnFetchConfig = document.getElementById("btnFetchConfig");
    const btnFetchArcV2 = document.getElementById("btnFetchArcV2");
    const btnLoadFromApi = document.getElementById("btnLoadFromApi");
    const payloadTextArea = document.querySelector("textarea[name='payload']");

    function setHttp(status, etag, body) {
      if (statusInput) statusInput.value = status || "";
      if (etagInput) etagInput.value = etag || "";
      if (bodyArea) bodyArea.value = body || "";
    }

    async function fetchJson(url) {
      const res = await fetch(url, { headers: { "Accept": "application/json" } });
      const etag = res.headers.get("etag") || "";
      const text = await res.text();
      setHttp("HTTP " + res.status + " " + res.statusText, etag, text);
      return { res, etag, text };
    }

    if (btnFetchManifest) btnFetchManifest.addEventListener("click", function () { fetchJson("/api/content/manifest"); });
    if (btnFetchConfig) btnFetchConfig.addEventListener("click", function () { fetchJson("/api/app-config"); });
    if (btnFetchArcV2) btnFetchArcV2.addEventListener("click", function () { fetchJson("/api/arcanos/export/v2/arcanos.json"); });
    if (btnLoadFromApi) {
      btnLoadFromApi.addEventListener("click", async function () {
        const r = await fetchJson("/api/app-config");
        if (!payloadTextArea) return;
        try {
          const obj = JSON.parse(r.text);
          payloadTextArea.value = JSON.stringify(obj, null, 2);
        } catch {
          payloadTextArea.value = r.text;
        }
      });
    }
  })();
</script>

