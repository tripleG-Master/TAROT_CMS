<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Gemini · Generaciones</h1>
      <div class="muted">Últimas generaciones registradas.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <form class="d-flex gap-2 m-0" method="GET" action="/tarot/gemini/generations">
        <input class="form-control form-control-sm" style="max-width: 180px;" name="user_id" placeholder="user_id" value="{{filters.user_id}}" />
        <button class="btn btn-sm btn-outline-info" type="submit">Filtrar</button>
        <a class="btn btn-sm btn-outline-secondary" href="/tarot/gemini/generations">Limpiar</a>
      </form>
      <a class="btn btn-outline-light" href="/tarot/gemini">Volver</a>
    </div>
  </div>

  <div class="card p-3">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 92px;">ID</th>
            <th style="width: 110px;">User</th>
            <th style="width: 190px;">Fecha</th>
            <th style="width: 160px;">Modelo</th>
            <th style="width: 140px;">Tema</th>
            <th style="width: 120px;">Status</th>
            <th>Pregunta</th>
            <th style="width: 220px;">Fingerprint</th>
          </tr>
        </thead>
        <tbody>
          {{#unless generations.length}}
            <tr>
              <td colspan="8" class="py-4">
                <div class="muted">Sin generaciones.</div>
              </td>
            </tr>
          {{/unless}}
          {{#each generations}}
            <tr>
              <td><span class="badge badge-mystic text-dark">{{id}}</span></td>
              <td class="text-nowrap">
                {{#if user_id}}
                  <a class="btn btn-sm btn-outline-info py-0" href="/tarot/users?user_id={{user_id}}">{{user_id}}</a>
                {{else}}
                  <span class="muted">—</span>
                {{/if}}
              </td>
              <td class="muted">{{createdAt}}</td>
              <td class="text-truncate" style="max-width: 160px;">{{model}}</td>
              <td>{{tema}}</td>
              <td>{{status}}</td>
              <td class="text-truncate" style="max-width: 520px;">{{pregunta}}</td>
              <td class="text-truncate" style="max-width: 220px;">{{fingerprint}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</main>
