<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Gemini · Generaciones</h1>
      <div class="muted">Historial de lecturas y generaciones realizadas con Gemini.</div>
    </div>
    <a class="btn btn-outline-light" href="/tarot/gemini">Volver a prueba</a>
  </div>

  <div class="card p-3 mb-3">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">API Token</label>
        <input id="apiToken" class="form-control" type="password" placeholder="Bearer..." />
        <div class="muted mt-1">Token del CMS para poder llamar endpoints /api.</div>
      </div>
    </div>
  </div>

  <div class="card p-3">
    <div class="table-responsive">
      <table class="table table-sm align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>Fecha</th>
            <th>Modelo</th>
            <th>Tema</th>
            <th>Pregunta</th>
            <th>Texto</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#if generations.length}}
            {{#each generations}}
              <tr data-id="{{id}}">
                <td class="text-nowrap">{{id}}</td>
                <td class="text-nowrap">{{createdAt}}</td>
                <td class="text-nowrap"><span class="badge bg-secondary">{{model}}</span></td>
                <td class="text-nowrap">{{#if tema}}{{tema}}{{else}}—{{/if}}</td>
                <td class="text-nowrap">{{#if pregunta}}{{pregunta}}{{else}}—{{/if}}</td>
                <td style="max-width: 340px;">
                  {{#if response_text}}
                    {{response_text}}
                  {{else}}—{{/if}}
                </td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-info me-2 js-toggle">Ver JSON</button>
                  <button class="btn btn-sm btn-mystic text-dark fw-semibold js-promote">Promover a plantilla</button>
                </td>
              </tr>
              <tr class="d-none js-json-row" data-id="{{id}}">
                <td colspan="7">
                  <div class="bg-dark p-2 rounded">
                    <div class="fw-semibold mb-1">Request</div>
                    <pre class="mb-2" style="white-space: pre-wrap; word-break: break-word;">{{json request_payload}}</pre>
                    <div class="fw-semibold mb-1">Raw</div>
                    <pre style="white-space: pre-wrap; word-break: break-word;">{{json response_raw}}</pre>
                  </div>
                </td>
              </tr>
            {{/each}}
          {{else}}
            <tr><td colspan="7" class="text-center py-4">Sin registros aún.</td></tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </div>
</main>

<script>
  (function () {
    const apiToken = document.getElementById("apiToken");
    apiToken.value = localStorage.getItem("tarotCmsApiToken") || "";
    apiToken.addEventListener("change", () => localStorage.setItem("tarotCmsApiToken", apiToken.value || ""));

    function headers() {
      const h = { "Accept": "application/json", "Content-Type": "application/json" };
      const t = apiToken.value || "";
      if (t) h["Authorization"] = "Bearer " + t;
      return h;
    }

    document.querySelectorAll(".js-toggle").forEach((btn) => {
      btn.addEventListener("click", function () {
        const tr = this.closest("tr");
        const id = tr && tr.getAttribute("data-id");
        if (!id) return;
        const row = document.querySelector('.js-json-row[data-id="' + id + '"]');
        if (row) row.classList.toggle("d-none");
      });
    });

    document.querySelectorAll(".js-promote").forEach((btn) => {
      btn.addEventListener("click", async function () {
        const tr = this.closest("tr");
        const id = tr && tr.getAttribute("data-id");
        if (!id) return;
        try {
          const res = await fetch("/api/gemini/generations/" + id + "/promote", {
            method: "POST",
            headers: headers()
          });
          const data = await res.json().catch(() => null);
          if (res.status === 401) return alert("Unauthorized. Pega el API token para usar /api.");
          if (!res.ok || !data || data.ok !== true) return alert((data && data.error) || ("HTTP " + res.status));
          alert("Promovido a plantilla #" + (data && data.template && data.template.id));
        } catch (err) {
          alert(err && err.message ? err.message : "Error de red");
        }
      });
    });
  })();
</script>
