<main class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="h3 brand mb-1">Tipos (Android)</h1>
      <div class="muted">Playground para probar los tipos de tarot que usa la app Kotlin contra el backend.</div>
    </div>
    <a class="btn btn-outline-light" href="/tarot/lectura">Volver</a>
  </div>

  <div class="card p-3">
    <form id="typesForm" class="row g-3">
      <div class="col-md-4">
        <label class="form-label">Tipo</label>
        <select id="tarotType" class="form-select">
          <option value="yes_no">Tarot Sí/No</option>
          <option value="daily" selected>Tarot Diario</option>
          <option value="theme">Tarot Amor/Salud/Dinero</option>
          <option value="question_gemini">Tarot con Pregunta (Gemini)</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Mazo</label>
        <select id="deckId" class="form-select">
          {{#each decks}}
            <option value="{{id}}" {{#if (eq id ../defaultDeckId)}}selected{{/if}}>{{nombre}}</option>
          {{/each}}
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">External ID</label>
        <div class="input-group">
          <input id="externalId" class="form-control" placeholder="ANDROID_ID / UUID" />
          <button id="genExternalId" class="btn btn-outline-secondary" type="button">Generar</button>
        </div>
      </div>

      <div class="col-md-4" id="themeWrap">
        <label class="form-label">Tema</label>
        <select id="tema" class="form-select">
          <option value="general" selected>General</option>
          <option value="amor">Amor</option>
          <option value="salud">Salud</option>
          <option value="dinero">Dinero</option>
        </select>
      </div>
      <div class="col-md-4" id="questionWrap">
        <label class="form-label">Pregunta</label>
        <input id="pregunta" class="form-control" placeholder="¿Debo cambiar de trabajo?" />
      </div>
      <div class="col-md-4" id="geminiModeWrap">
        <label class="form-label">Modo Gemini</label>
        <select id="readingMode" class="form-select">
          <option value="free">Free</option>
          <option value="premium" selected>Premium</option>
        </select>
      </div>

      <div class="col-12 d-flex gap-2 flex-wrap">
        <button class="btn btn-mystic text-dark fw-semibold" type="submit">Probar</button>
        <button class="btn btn-outline-secondary" type="button" id="btnClear">Limpiar</button>
      </div>
    </form>
  </div>

  <div class="row g-3 mt-1">
    <div class="col-lg-6">
      <div class="card p-3">
        <div class="fw-semibold mb-2">Request</div>
        <textarea id="reqBox" class="form-control" rows="14" spellcheck="false" readonly></textarea>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card p-3">
        <div class="fw-semibold mb-2">Response</div>
        <textarea id="resBox" class="form-control" rows="14" spellcheck="false" readonly></textarea>
      </div>
    </div>
  </div>
</main>

<script>
  (function () {
    const tarotType = document.getElementById("tarotType");
    const deckId = document.getElementById("deckId");
    const externalId = document.getElementById("externalId");
    const genExternalId = document.getElementById("genExternalId");
    const tema = document.getElementById("tema");
    const pregunta = document.getElementById("pregunta");
    const readingMode = document.getElementById("readingMode");
    const themeWrap = document.getElementById("themeWrap");
    const questionWrap = document.getElementById("questionWrap");
    const geminiModeWrap = document.getElementById("geminiModeWrap");
    const reqBox = document.getElementById("reqBox");
    const resBox = document.getElementById("resBox");
    const btnClear = document.getElementById("btnClear");
    const form = document.getElementById("typesForm");

    const deckData = {{#if decks.length}}{{{json decks}}}{{else}}[]{{/if}};
    const deckById = new Map((deckData || []).map((d) => [String(d.id), d]));

    function randomHex(len) {
      const chars = "0123456789abcdef";
      let out = "";
      for (let i = 0; i < len; i += 1) out += chars[Math.floor(Math.random() * chars.length)];
      return out;
    }

    function generateExternalId() {
      if (window.crypto && typeof window.crypto.randomUUID === "function") return window.crypto.randomUUID();
      return "web-" + randomHex(32);
    }

    function allArcanaValues() {
      const id = deckId ? String(deckId.value || "") : "";
      const deck = deckById.get(id);
      const nums = deck && Array.isArray(deck.card_numeros) ? deck.card_numeros : [];
      return nums.map((n) => Number(n)).filter((n) => Number.isInteger(n));
    }

    function pickDistinct(values, count) {
      const pool = Array.isArray(values) ? values.slice() : [];
      const out = [];
      while (out.length < count && pool.length > 0) {
        const i = Math.floor(Math.random() * pool.length);
        out.push(pool.splice(i, 1)[0]);
      }
      return out;
    }

    function setBoxes(req, res) {
      if (reqBox) reqBox.value = req ? JSON.stringify(req, null, 2) : "";
      if (resBox) resBox.value = res ? JSON.stringify(res, null, 2) : "";
    }

    function updateVisibility() {
      const t = tarotType.value;
      const showTheme = t === "theme" || t === "question_gemini";
      const showQuestion = t === "yes_no" || t === "question_gemini";
      const showGeminiMode = t === "question_gemini";
      if (themeWrap) themeWrap.style.display = showTheme ? "" : "none";
      if (questionWrap) questionWrap.style.display = showQuestion ? "" : "none";
      if (geminiModeWrap) geminiModeWrap.style.display = showGeminiMode ? "" : "none";
    }

    if (genExternalId) genExternalId.addEventListener("click", function () { externalId.value = generateExternalId(); });
    if (btnClear) btnClear.addEventListener("click", function () { setBoxes(null, null); });
    if (tarotType) tarotType.addEventListener("change", updateVisibility);
    updateVisibility();

    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      try {
        const type = tarotType.value;
        const deck_id = deckId.value || "";
        const external_id = String(externalId.value || "").trim();
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || "UTC";
        const loc = (navigator.language || "es-CL");
        const picked = pickDistinct(allArcanaValues(), 3);
        const cards = picked.length === 3 ? picked : [0, 1, 2];

        let url = "";
        let payload = {};

        if (type === "daily") {
          url = "/api/tarot/daily";
          payload = { external_id, timezone: tz, locale: loc, deck_id };
        } else if (type === "yes_no") {
          url = "/api/tarot/yes-no";
          payload = { external_id, timezone: tz, locale: loc, pregunta: String(pregunta.value || "").trim() };
        } else if (type === "theme") {
          url = "/api/narrative/three-cards";
          payload = {
            external_id,
            deck_id,
            tema: tema.value || "general",
            user_data: { nombre: "", genero: "", nacimiento: "" },
            tirada: {
              cards: [
                { id: Number(cards[0]), posicion: "pasado", orientacion: "upright" },
                { id: Number(cards[1]), posicion: "presente", orientacion: "upright" },
                { id: Number(cards[2]), posicion: "futuro", orientacion: "upright" }
              ]
            }
          };
        } else if (type === "question_gemini") {
          url = "/api/gemini/tarot-reading";
          payload = {
            external_id,
            deck_id,
            tema: tema.value || "general",
            pregunta: String(pregunta.value || "").trim(),
            reading_mode: String(readingMode.value || "premium"),
            includeContext: true,
            includePrompt: false,
            card_source: "",
            user_data: { nombre: "", genero: "", nacimiento: "" },
            tirada: {
              cards: [
                { id: Number(cards[0]), posicion: "pasado", orientacion: "upright" },
                { id: Number(cards[1]), posicion: "presente", orientacion: "upright" },
                { id: Number(cards[2]), posicion: "futuro", orientacion: "upright" }
              ]
            }
          };
        }

        setBoxes(payload, null);
        const res = await fetch(url, { method: "POST", headers: { "Accept": "application/json", "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        const data = await res.json().catch(() => null);
        setBoxes(payload, data);
      } catch (err) {
        setBoxes(null, { ok: false, error: err && err.message ? err.message : "Error" });
      }
    });
  })();
</script>

